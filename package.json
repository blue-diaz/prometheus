{
  "name": "doc-prometheus",
  "version": "0.10.8",
  "type": "module",
  "description": "Coceira no boga.",
  "author": "Black Diaz",
  "license": "MIT-0",
  "bin": {
    "prometheus": "./dist/bin/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./sdk": "./dist/sdk/index.js",
    "./api": "./dist/api/server.js",
    "./types": "./dist/types/index.js",
    "./bin": "./dist/bin/index.js"
  },
  "engines": {
    "node": ">=24.16.0"
  },
  "scripts": {
    "prebuild": "rimraf dist bin *.tsbuildinfo",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "build:web": "next build",
    "prepare": "npm run build",
    "dev": "next dev --port 3001",
    "start": "prometheus",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --ext .ts src",
    "test": "vitest run --passWithNoTests",
    "coverage": "vitest run --coverage",
    "diagnosticar": "prometheus diagnosticar",
    "imports": "prometheus imports",
    "imports:scan": "prometheus imports --scan",
    "imports:apply": "prometheus imports --apply",
    "formatar": "prometheus formatar --write",
    "format:check": "prometheus formatar --check",
    "podar": "prometheus podar",
    "fix-types": "prometheus fix-types",
    "name": "prometheus names",
    "names:scan": "prometheus names --scan",
    "names:apply": "prometheus names --apply",
    "barrels": "prometheus barrels",
    "perf:baseline": "prometheus perf snapshot --baseline || true",
    "perf:compare": "prometheus perf compare",
    "perf:gate": "prometheus perf compare --threshold 0",
    "scan": "prometheus licencas scan",
    "scan:root": "prometheus licencas scan --root .",
    "notices": "prometheus licencas notices generate",
    "disclaimer:add": "prometheus licencas disclaimer add",
    "disclaimer:verify": "prometheus licencas disclaimer verify",
    "add": "prometheus licencas disclaimer add",
    "verify": "prometheus licencas disclaimer verify",
    "audit": "prometheus licencas scan",
    "licenses:audit": "prometheus licencas scan",
    "licenses:json": "prometheus licencas scan --json",
    "licenses:notice": "prometheus licencas notices generate",
    "json": "prometheus licencas scan --json",
    "guardian": "prometheus guardian",
    "otimizar-svg": "prometheus otimizar-svg --write",
    "atualizar": "prometheus atualizar",
    "convert": "prometheus convert",
    "analistas": "prometheus analistas",
    "metricas": "prometheus metricas",
    "vulnerabilidades": "prometheus vulnerabilidades scan",
    "security:deps": "prometheus vulnerabilidades scan",
    "security:lint": "npm run lint",
    "security-check": "npm audit --production --audit-level=moderate",
    "gha:scan": "prometheus github-actions scan",
    "gha:report": "prometheus github-actions report",
    "gha:gate": "prometheus github-actions gate",
    "gha:app": "prometheus github-actions app",
    "gitlab:scan": "prometheus gitlab-ci scan",
    "circleci:scan": "prometheus circleci scan",
    "jenkins:scan": "prometheus jenkins scan",
    "azure:scan": "prometheus azure scan",
    "plugins:list": "prometheus plugins list",
    "marketplace:search": "prometheus marketplace search",
    "marketplace:list": "prometheus marketplace list",
    "reverter:listar": "prometheus reverter listar",
    "reverter:status": "prometheus reverter status",
    "headers:spdx": "find src -name \"*.ts\" -exec grep -L \"SPDX-License-Identifier\" {} \\; 2>/dev/null | head -20",
    "license-check": "npx license-checker-rseidelsohn --production --onlyAllow=\"MIT;MIT-0;ISC;BSD-2-Clause;BSD-3-Clause;Apache-2.0;0BSD;Unlicense;CC0-1.0;BlueOak-1.0.0;Python-2.0;Zlib;CC-BY-3.0;CC-BY-4.0;Artistic-2.0;BSD-2-Clause-Patent;BSL-1.0;Unicode-DFS-2015;Unicode-DFS-2016;Unicode-3.0\""
  },
  "keywords": [
    "cli",
    "code-analysis",
    "linter",
    "static-analysis",
    "typescript",
    "javascript",
    "developer-tools",
    "code-quality",
    "architecture",
    "refactoring",
    "monorepo",
    "project-analysis",
    "technical-debt",
    "devtools",
    "maintenance",
    "diagnostics",
    "code-health"
  ],
  "dependencies": {
    "prometheus-cli": "^0.11.5"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.15"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ]
  }
}
